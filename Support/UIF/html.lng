			<token>form</token>
			<token>frame</token>
			<token>frameset</token>
			<token>h1</token>
			<token>h2</token>
			<token>h3</token>
			<token>h4</token>
			<token>h5</token>
			<token>h6</token>
			<token>head</token>
			<token>hr</token>
			<token>html</token>
			<token>i</token>
			<token>iframe</token>
			<token>img</token>
			<token>input</token>
			<token>ins</token>
			<token>isindex</token>
			<token>kbd</token>
			<token>label</token>
			<token>legend</token>
			<token>li</token>
			<token>link</token>
			<token>map</token>
			<token>menu</token>
			<token>meta</token>
			<token>noframes</token>
			<token>noscript</token>
			<token>object</token>
			<token>ol</token>
			<token>optgroup</token>
			<token>option</token>
			<token>p</token>
			<token>param</token>
			<token>pre</token>
			<token>q</token>
			<token>s</token>
