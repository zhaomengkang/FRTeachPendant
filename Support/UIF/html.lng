<language name="HTML" casesensitive="no" wordchars="[\w]">
	<tokenset name="Comments" id="blockcomments" type="scope" forecolor="green" fontstyle="italic">
		<validscope name=""/>
		<tokens>
			<token>&lt;!--</token>
			<token>&lt;comment&gt;</token>
		</tokens>
		<tokens2>
			<token>--&gt;</token>
			<token>&lt;/comment&gt;</token>
		</tokens2>
	</tokenset>
	<tokenset name="Tag Delimiters" id="tagdelimiters" type="scope" forecolor="blue">
		<validscope name=""/>
		<tokens>
			<token action="ListMembers">&lt;</token>
			<token action="ListMembers">&lt;/</token>
		</tokens>
		<tokens2>
			<token action="commitmember">&gt;</token>
			<token action="commitmember">&gt;</token>
		</tokens2>
	</tokenset>
	<tokenset name="Strings" id="strings" type="scope" singlelinescope="yes" forecolor="purple">
		<validscope name="Tag Delimiters"/>
		<tokens>
			<token>"</token>
			<token>'</token>
		</tokens>
		<tokens2>
			<token>"</token>
			<token>'</token>
		</tokens2>
	</tokenset>
	<tokenset name="Element Names" id="tagelementnames" forecolor="maroon" fontstyle="bold">
		<validscope name="Tag Delimiters"/>
		<tokens rule="leadwith[&lt;]|trailwith[&gt;]">
			<token>a</token>
			<token>abbr</token>
			<token>acronym</token>
			<token>address</token>
			<token>applet</token>
			<token>area</token>
			<token>b</token>
			<token>base</token>
			<token>basefont</token>
			<token>bdo</token>
			<token>big</token>
			<token>blockquote</token>
			<token>body</token>
			<token>br</token>
			<token>button</token>
			<token>caption</token>
			<token>center</token>
			<token>cite</token>
			<token>code</token>
			<token>col</token>
			<token>colgroup</token>
			<token>dd</token>
			<token>del</token>
			<token>dfn</token>
			<token>dir</token>
			<token>div</token>
			<token>dl</token>
			<token>dt</token>
			<token>em</token>
			<token>fieldset</token>
