			<token>select</token>
			<token>small</token>
			<token>span</token>
			<token>strike</token>
			<token>strong</token>
			<token>style</token>
			<token>sub</token>
			<token>sup</token>
			<token>table</token>
			<token>tbody</token>
			<token>td</token>
			<token>textarea</token>
			<token>tfoot</token>
			<token>th</token>
			<token>thead</token>
			<token>title</token>
			<token>tr</token>
			<token>tt</token>
			<token>u</token>
			<token>ul</token>
			<token>var</token>
		</tokens>
	</tokenset>
	<tokenset name="Attribute Names" id="tagattributenames" forecolor="blue">
		<validscope name="Tag Delimiters"/>
		<tokens>
			<token regexp="yes" rule="trailwith[=]">\w+([\-\w]*\w)?</token>
		</tokens>
	</tokenset>
