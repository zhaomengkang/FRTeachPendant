<language name="KAREL" casesensitive="no" wordchars="[\w$]" whitespaceasparamblock="1">
  <tokenset name="Line Comments" id="linecomments" type="scope" forecolor='32768' fontstyle="italic">
    <validscope name=""/>
    <validscope name="Scope Keywords"/>
    <tokens>
      <token>--</token>
    </tokens>
  </tokenset>
  <tokenset name="Strings" id="strings" type="scope" singlelinescope="yes" forecolor='12583104'>
    <validscope name=""/>
    <validscope name="Scope Keywords"/>
		<validscope name="Parameter Block"/>
    <tokens>
      <token>'</token>
    </tokens>
    <tokens2>
      <token>'</token>
    </tokens2>
  </tokenset>
	<tokenset name="Parameter Block" id="parameterblocks" type="scope" hidden="yes" inheritfrom="Text">
		<validscope name=""/>
		<validscope name="Scope Keywords"/>
		<validscope name="Parameter Block"/>
		<tokens>
 			<token action="ParameterInfo" regexp="yes">\s*\(</token>
		</tokens>
		<tokens2>
 			<token>)</token>
		</tokens2>
	</tokenset>
	<tokenset name="Argument Separators" id="argseparators" hidden="yes" inheritfrom="Text">
		<validscope name="Parameter Block"/>
		<tokens>
 			<token>,</token>
		</tokens>
	</tokenset>
